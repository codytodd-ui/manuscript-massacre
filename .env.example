# Copy to .env.local for local dev (with `vercel dev`), or set these in your
# Vercel/Netlify project's Environment Variables for production.

# Required: your Anthropic API key (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the model used for critiques (default: claude-sonnet-5)
# ANTHROPIC_MODEL=claude-sonnet-5
